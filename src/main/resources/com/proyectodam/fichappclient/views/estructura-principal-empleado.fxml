<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectodam.fichappclient.controller.EstructuraPrincipalEmpleadoController">
   <left>
      <VBox BorderPane.alignment="CENTER">
          <padding>
              <Insets bottom="15" left="10" right="10" top="15" />
          </padding>
         <children>
            <Label prefHeight="57.0" prefWidth="116.0" styleClass="logo-text" text="  LOGO EMPRESA" textAlignment="CENTER">
               <font>
                  <Font size="13.0" />
               </font>
            </Label>
            <Button fx:id="btnPanelCentral" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#showDashboard" prefHeight="37.0" prefWidth="116.0" maxWidth="Infinity" styleClass="boton-menu" text="Panel General" />
            <Button fx:id="btnControlHorario" maxWidth="Infinity" onAction="#handleControlHorarioBtn" prefHeight="37.0" prefWidth="101.0" styleClass="boton-menu" text="Control Horario" />
            <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Vacaciones" />
            <VBox spacing="2" maxWidth="Infinity">
                <children>
                    <ToggleButton fx:id="btnDocumentos" maxWidth="Infinity" prefHeight="37.0" prefWidth="101.0" styleClass="boton-menu" text="Documentos" />
                    <VBox fx:id="subDocumentosMenu" maxWidth="Infinity" managed="false" spacing="2" style="-fx-padding: 0 0 0 20;" visible="false">
                        <children>
                            <Button fx:id="btnNominas" maxWidth="Infinity" styleClass="sub-menu-button" text="Nóminas" />
                        </children>
                    </VBox>
                </children>
            </VBox>
            <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Tablón de Anuncios" />
            <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#showConfiguracion" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Configuración" />
         </children>
      </VBox>
   </left>
   <center>
      <StackPane fx:id="centerStackPane" prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
