<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="borderPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.proyectodam.fichappclient.controller.EstructuraPrincipalController">

    <left>
        <VBox BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15" left="10" right="10" top="15" />
            </padding>

            <children>
                <Label prefHeight="57.0" prefWidth="116.0" styleClass="logo-text" text="  LOGO EMPRESA" textAlignment="CENTER">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>

                <Button fx:id="btnPanelCentral"
                        alignment="BASELINE_LEFT"
                        mnemonicParsing="false"
                        prefHeight="37.0"
                        prefWidth="116.0"
                        maxWidth="Infinity"
                        styleClass="boton-menu"
                        text="Panel General"/>

                <VBox spacing="2" maxWidth="Infinity">
                    <children>
                        <ToggleButton fx:id="btnControlHorario"
                                      maxWidth="Infinity"
                                      onAction="#handleControlHorarioMenu"
                                      prefHeight="37.0"
                                      prefWidth="101.0"
                                      styleClass="boton-menu"
                                      text="Control Horario" />

                        <VBox fx:id="subControlHorarioMenu"
                              maxWidth="Infinity"
                              managed="false"
                              spacing="2"
                              style="-fx-padding: 0 0 0 20;"
                              visible="false">
                            <children>
                                <Button maxWidth="Infinity"
                                        onAction="#handleEmpleados"
                                        styleClass="sub-menu-button"
                                        text="Empleados" />
                                <Button maxWidth="Infinity"
                                        styleClass="sub-menu-button"
                                        text="Equipos" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- ✅ Este es el que te faltaba enlazar bien -->
                <Button fx:id="btnVacaciones"
                        alignment="BASELINE_LEFT"
                        mnemonicParsing="false"
                        prefHeight="37.0"
                        prefWidth="122.0"
                        maxWidth="Infinity"
                        styleClass="boton-menu"
                        text="Vacaciones"
                        onAction="#handleVacaciones"/>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Informes" />
                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Documentos" />
                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Tablón de Anuncios" />
                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Calendario" />
                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="37.0" prefWidth="122.0" maxWidth="Infinity" text="Configuración" />
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="centerStackPane"
                   prefHeight="150.0"
                   prefWidth="200.0"
                   BorderPane.alignment="CENTER" />
    </center>

</BorderPane>
