<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" fillWidth="false" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: -fx-background;" stylesheets="@../styles/main.css"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectodam.fichappclient.controller.ControladorLogin">
    <children>
        <VBox alignment="CENTER_LEFT" prefWidth="400.0" spacing="20.0" styleClass="tarjeta">
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label styleClass="encabezado" text="Fich-App">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label styleClass="label, tenue" text="Control Horario y Gestión" />
                    </children>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label" text="Entorno" />
                        <ComboBox fx:id="environmentSelector" maxWidth="1.7976931348623157E308" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label" text="Usuario" />
                        <TextField fx:id="usernameField" promptText="ej. empleado@empresa.com" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label" text="Contraseña" />
                        <PasswordField fx:id="passwordField" promptText="••••••••" />
                    </children>
                </VBox>
                <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" styleClass="button" text="Iniciar Sesión">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
                <Label fx:id="errorLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" textFill="#d32f2f" visible="false" />
            </children>
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
        </VBox>
    </children>
</VBox>
