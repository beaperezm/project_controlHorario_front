<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.SVGPath?>

<VBox alignment="TOP_CENTER" spacing="40.0" styleClass="dashboard-container" stylesheets="@../styles/dashboard_usuario.css"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectodam.fichappclient.controller.UserDashboardController">

    <!-- Top Header Area with Clock -->
    <HBox alignment="CENTER_LEFT" prefHeight="120.0">
        <children>
            <VBox alignment="CENTER_LEFT">
                <children>
                    <javafx.scene.image.ImageView fitHeight="100.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <javafx.scene.image.Image url="@../img/logo_fichapp.png" />
                        </image>
                    </javafx.scene.image.ImageView>
                </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT" styleClass="clock-container">
                <children>
                    <Label fx:id="clockLabel" styleClass="clock-text" text="--:--:--" />
                    <Label fx:id="dateLabel" styleClass="date-text" text="Cargando fecha..." />
                </children>
            </VBox>
        </children>
        <padding>
            <Insets left="20.0" right="20.0" />
        </padding>
    </HBox>

    <!-- Tiles Grid Area -->
    <GridPane alignment="CENTER" hgap="30.0" vgap="30.0" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <javafx.scene.layout.ColumnConstraints hgrow="SOMETIMES" minWidth="280.0" prefWidth="320.0" />
            <javafx.scene.layout.ColumnConstraints hgrow="SOMETIMES" minWidth="280.0" prefWidth="320.0" />
        </columnConstraints>
        <rowConstraints>
            <javafx.scene.layout.RowConstraints minHeight="180.0" prefHeight="220.0" vgrow="SOMETIMES" />
            <javafx.scene.layout.RowConstraints minHeight="180.0" prefHeight="220.0" vgrow="SOMETIMES" />
        </rowConstraints>

        <children>
            <!-- Card 1: Quiosco (Fichaje) -->
            <VBox alignment="CENTER" onMouseClicked="#handleQuiosco" spacing="20.0" styleClass="glass-tile, tile-quiosco" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <children>
                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8c4.42 0 8 3.58 8 8s-3.58 8-8 8zm0.5-13H11v6l5.25 3.15 0.75-1.23-4.5-2.67V7z" styleClass="tile-icon" />
                    <Label styleClass="tile-label" text="CONTROL HORARIO" />
                </children>
            </VBox>

            <!-- Card 2: Documentación -->
            <VBox alignment="CENTER" onMouseClicked="#handleDocumentacion" spacing="20.0" styleClass="glass-tile, tile-docs" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <children>
                    <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" styleClass="tile-icon" />
                    <Label styleClass="tile-label" text="NÓMINAS Y DOCUMENTOS" />
                </children>
            </VBox>

            <!-- Card 3: Vacaciones -->
            <VBox alignment="CENTER" onMouseClicked="#handleVacaciones" spacing="20.0" styleClass="glass-tile, tile-vacaciones" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <children>
                    <SVGPath content="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z" styleClass="tile-icon" />
                    <Label styleClass="tile-label" text="SOLICITUD VACACIONES" />
                </children>
            </VBox>

            <!-- Card 4: Configuración / Perfil -->
            <VBox alignment="CENTER" onMouseClicked="#handleConfiguracion" spacing="20.0" styleClass="glass-tile, tile-config" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <children>
                    <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" styleClass="tile-icon" />
                    <Label styleClass="tile-label" text="MI PERFIL" />
                </children>
            </VBox>
        </children>
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
    </GridPane>

    <!-- Footer info and Logout -->
    <VBox alignment="CENTER" spacing="15.0">
        <children>
            <HBox alignment="CENTER">
                <children>
                    <Label fx:id="footerLabel" style="-fx-text-fill: #adb5bd;" text="Cargando información de usuario..." />
                </children>
            </HBox>
            <Button onAction="#handleLogout" styleClass="boton-logout" text="CERRAR SESIÓN">
                <graphic>
                    <SVGPath content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" styleClass="svg-path" />
                </graphic>
            </Button>
        </children>
        <padding>
            <Insets bottom="20.0" />
        </padding>
    </VBox>
</VBox>
