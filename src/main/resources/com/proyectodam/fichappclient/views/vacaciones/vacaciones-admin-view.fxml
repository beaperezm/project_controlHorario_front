<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/17"
  xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectodam.fichappclient.controller.VacacionesAdminController" spacing="20" style="-fx-padding: 24; -fx-background-color: #f8f9fa;">

  <!-- Cabecera (sin botón volver) -->
  <VBox spacing="5" alignment="CENTER_LEFT">
     <Label text="Gestión de Vacaciones" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
  </VBox>

  <!-- Barra de búsqueda e información -->
  <HBox spacing="25" VBox.vgrow="NEVER" alignment="TOP_LEFT">
    <!-- Panel del Buscador -->
    <VBox spacing="12" prefWidth="550" maxWidth="600" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12; -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 8, 0, 0, 4);" HBox.hgrow="NEVER">
       <Label text="Búsqueda de Empleado" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;"/>
       <HBox spacing="15" alignment="CENTER_LEFT">
          <TextField fx:id="txtBuscarEmpleado" promptText="Escribe un nombre, apellidos o ID..." maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-font-size: 14px; -fx-background-color: #f8f9fa; -fx-border-color: #ced4da; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 10;"/>
          <Button text="Limpiar Filtro" onAction="#onLimpiarBusqueda" style="-fx-cursor: hand; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-text-fill: #7f8c8d; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 18; -fx-font-weight: bold;"/>
       </HBox>
       <Label text="* Tip: Haz clic izquierdo sobre cualquier fila de la tabla para ver el perfil del trabajador abajo." style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Tarjeta Perfil de Empleado (Oculta por defecto) -->
    <VBox fx:id="tarjetaEmpleadoPanel" managed="false" visible="false" spacing="10" prefWidth="350" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12; -fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(52,152,219,0.15), 10, 0, 0, 5);" HBox.hgrow="NEVER">
       <HBox alignment="CENTER_LEFT" spacing="18">
          <VBox alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #3498db, #2980b9); -fx-background-radius: 50%; -fx-min-width: 56; -fx-min-height: 56;">
             <Label text="👤" style="-fx-font-size: 26px; -fx-text-fill: white;"/>
          </VBox>
          <VBox spacing="4">
             <Label fx:id="lblNombreEmpleado" text="Nombre Empleado" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #2c3e50;"/>
             <Label fx:id="lblEmailEmpleado" text="email@ejemplo.com" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
             <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
                <Label text="ID Empleado:" style="-fx-font-weight: normal; -fx-text-fill: #95a5a6; -fx-font-size: 12px;"/>
                <Label fx:id="lblIdEmpleado" text="000" style="-fx-font-weight: bold; -fx-text-fill: #2980b9; -fx-font-size: 13px; -fx-background-color: #ebf5fb; -fx-padding: 2 6; -fx-background-radius: 4;"/>
             </HBox>
          </VBox>
       </HBox>
    </VBox>
  </HBox>

  <!-- Panel de Estado -->
  <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 0 0 0;">
     <Label fx:id="estadoLabel" text="" style="-fx-font-weight: bold; -fx-text-fill: #f39c12; -fx-font-size: 13px;"/>
     <Region HBox.hgrow="ALWAYS"/>
     <Button text="  🔄 Sincronizar  " onAction="#onVerSolicitudesClick" style="-fx-cursor: hand; -fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20; -fx-font-weight: bold;"/>
  </HBox>

  <!-- Tabla de Resultados -->
  <TableView fx:id="tablaSolicitudes" prefHeight="450.0" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 6, 0, 0, 3); -fx-fixed-cell-size: 45; -fx-font-size: 13px;">
    <columnResizePolicy>
        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
    </columnResizePolicy>
    <columns>
      <TableColumn fx:id="colId" text="Ref." prefWidth="60" style="-fx-alignment: CENTER;"/>
      <TableColumn fx:id="colEmpleado" text="Empleado Solicitante" prefWidth="280" style="-fx-alignment: CENTER;"/>
      <TableColumn fx:id="colTipo" text="Tipo" prefWidth="130" style="-fx-alignment: CENTER;"/>
      <TableColumn fx:id="colInicio" text="Fecha Inicio" prefWidth="130" style="-fx-alignment: CENTER;"/>
      <TableColumn fx:id="colFin" text="Fecha Fin" prefWidth="130" style="-fx-alignment: CENTER;"/>
      <TableColumn fx:id="colDias" text="Días Computables" prefWidth="140" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
      <TableColumn fx:id="colEstado" text="Estado Actual" prefWidth="140" style="-fx-alignment: CENTER;"/>
      <TableColumn fx:id="colAcciones" text="Resolución" prefWidth="130" style="-fx-alignment: CENTER;"/>
    </columns>
  </TableView>

</VBox>
