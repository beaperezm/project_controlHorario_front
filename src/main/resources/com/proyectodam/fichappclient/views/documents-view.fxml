<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox alignment="TOP_LEFT" spacing="20.0" style="-fx-background-color: -fx-background;" stylesheets="@../styles/main.css"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectodam.fichappclient.controller.ControladorDocumentos">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox.margin>
            <Insets bottom="5.0" />
        </VBox.margin>
        <children>
            <Label text="Gestión de Documentos" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5D4037;" />
        </children>
    </HBox>

    <!-- Sección de Filtros -->
    <VBox spacing="10.0" styleClass="tarjeta">
        <children>
            <Label text="Filtro" styleClass="subtitulo" />

            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <children>
                    <TextField fx:id="searchEmpleadoField" promptText="Buscar por nombre de empleado" prefWidth="250.0" />
                    <TextField fx:id="searchField" promptText="Buscar por archivo" prefWidth="250.0" />
                    <ComboBox fx:id="typeCombo" promptText="Tipo Documento" prefWidth="200.0" />
                    <ComboBox fx:id="groupCombo" promptText="Departamento" prefWidth="180.0" />
                    <ComboBox fx:id="yearComboBox" promptText="Tiempo" prefWidth="120.0" />
                </children>
            </HBox>

            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <children>
                    <Button text="Aplicar filtro" styleClass="boton-primario" />
                    <Button text="Limpiar" styleClass="boton-secundario" onAction="#limpiarFiltros" />
                </children>
            </HBox>
        </children>
    </VBox>

    <!-- Sección de Tabla -->
    <VBox spacing="10.0" styleClass="tarjeta" VBox.vgrow="ALWAYS">
        <children>
            <TableView fx:id="documentsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSelect" prefWidth="50.0" reorderable="false" sortable="false" style="-fx-alignment: CENTER;">
                        <graphic>
                            <CheckBox fx:id="selectAllCheck" mnemonicParsing="false" />
                        </graphic>
                    </TableColumn>
                    <TableColumn fx:id="colName" text="Nombre Empleado" prefWidth="250.0" style="-fx-alignment: CENTER;" />
                    <TableColumn fx:id="colType" text="Nombre Documento" prefWidth="250.0" style="-fx-alignment: CENTER;" />
                    <TableColumn fx:id="colGroup" text="Tipo de Documento" prefWidth="150.0" style="-fx-alignment: CENTER;" />
                    <TableColumn fx:id="colActions" text="Acción Rápida" prefWidth="120.0" style="-fx-alignment: CENTER;" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <!-- Paginación / Pie de acciones -->
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <children>
                    <Label fx:id="paginationLabel" text="Mostrando 0 de 0" style="-fx-text-fill: -fx-text-secondary;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Refrescar" styleClass="boton-secundario" onAction="#initialize" />
                    <Button text="Cargar Documento" styleClass="boton-secundario" onAction="#accionSubirSintetica" />
                    <HBox spacing="5.0">
                        <Button styleClass="boton-icono" onAction="#paginaAnterior">
                            <graphic>
                                <SVGPath content="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" fill="white"/>
                            </graphic>
                        </Button>
                        <Button styleClass="boton-icono" onAction="#paginaSiguiente">
                            <graphic>
                                <SVGPath content="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" fill="white"/>
                            </graphic>
                        </Button>
                        <Button styleClass="boton-icono-peligro" onAction="#borrarSeleccion">
                            <graphic>
                                <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="white"/>
                            </graphic>
                        </Button>
                    </HBox>
                </children>
                <padding>
                    <Insets top="10.0" />
                </padding>
            </HBox>
        </children>
    </VBox>
</VBox>
