<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootContainer" alignment="TOP_CENTER" spacing="30" styleClass="clocking-container" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.proyectodam.fichappclient.controller.ControlHorario.ControlHorarioEmpleadoController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 0 4 0;">
        <children>
            <Button onAction="#handleBack" styleClass="btn-back-dark">
                <graphic>
                    <SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="white" scaleX="1.2" scaleY="1.2" />
                </graphic>
                <tooltip>
                    <Tooltip text="Volver al Dashboard" />
                </tooltip>
            </Button>
            <Label text="CONTROL DE TIEMPO" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5D4037;" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="nombreLabel" styleClass="user-name-label text-white" text="Nombre Empleado" />
                <Label text="EMPLEADO" style="-fx-font-size: 10px; -fx-font-family: 'Segoe UI Semibold'; -fx-text-fill: rgba(255,255,255,0.35); -fx-letter-spacing: 1.5px;" />
            </VBox>
            <ImageView fx:id="imgPerfil" fitHeight="50" fitWidth="50" preserveRatio="true" />
        </children>
    </HBox>

    <!-- Main Clocking Panel -->
    <VBox alignment="CENTER" spacing="50" styleClass="dark-clocking-bar">
        <children>
            <HBox alignment="CENTER" spacing="90">
                <children>
                    <VBox alignment="CENTER" spacing="10">
                        <Label text="TIEMPO TRABAJADO HOY" styleClass="info-label text-white-muted" />
                        <Label fx:id="contadorLabel" text="00:00:00" styleClass="main-counter text-white" />
                    </VBox>
                    
                    <Separator orientation="VERTICAL" prefHeight="80" />
                    
                    <HBox spacing="40" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="5">
                            <Label text="HORAS EXTRA" styleClass="small-info-label text-white-muted" />
                            <Label fx:id="horasExtraLabel" text="00:00:00" styleClass="small-info-value text-white" />
                        </VBox>
                        <VBox alignment="CENTER" spacing="5">
                            <Label text="BOLSA DE HORAS" styleClass="small-info-label text-white-muted" />
                            <Label fx:id="bolsaHorasLabel" text="00:00:00" styleClass="small-info-value text-white" />
                        </VBox>
                    </HBox>
                </children>
            </HBox>

            <HBox alignment="CENTER" spacing="25">
                <children>
                    <Button fx:id="btnEntrada" onAction="#ficharEntrada" styleClass="btn-clocking btn-entrada" text="INICIAR JORNADA" />
                    <Button fx:id="btnDescanso" onAction="#ficharDescanso" styleClass="btn-clocking btn-descanso" text="DESCANSO" />
                    <Button fx:id="btnSalida" onAction="#ficharSalida" styleClass="btn-clocking btn-salida" text="FINALIZAR JORNADA" />
                </children>
            </HBox>
        </children>
    </VBox>

    <!-- Tables Section -->
    <HBox spacing="30" VBox.vgrow="ALWAYS">
        <children>
            <!-- Today's Table -->
            <VBox spacing="10" HBox.hgrow="SOMETIMES" styleClass="dark-glass-tile" style="-fx-padding: 15; -fx-cursor: default;">
                <children>
                    <HBox alignment="CENTER_LEFT" styleClass="table-header-box">
                        <SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z" fill="white" scaleX="0.8" scaleY="0.8" />
                        <Label text="REGISTRO DE HOY" styleClass="table-title-label"/>
                    </HBox>
                    <TableView fx:id="tablaHoy" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colFechaHoy" prefWidth="80" text="Fecha" />
                            <TableColumn fx:id="colEntradaHoy" prefWidth="70" text="Entrada" />
                            <TableColumn fx:id="colDescansoHoy" prefWidth="70" text="Pausa" />
                            <TableColumn fx:id="colSalidaHoy" prefWidth="70" text="Salida" />
                            <TableColumn fx:id="colTipoHoy" prefWidth="90" text="Evento" />
                            <TableColumn fx:id="colServidorHoy" prefWidth="70" text="Servidor" />
                        </columns>
                    </TableView>
                </children>
            </VBox>

            <!-- History Table -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="dark-glass-tile" style="-fx-padding: 15; -fx-cursor: default;">
                <children>
                    <HBox alignment="CENTER_LEFT" styleClass="table-header-box">
                        <SVGPath content="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8h-1.5z" fill="white" scaleX="0.8" scaleY="0.8" />
                        <Label text="HISTÓRICO RECIENTE" styleClass="table-title-label"/>
                    </HBox>
                    <TableView fx:id="tablaHistorico" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colFechaHist" prefWidth="90" text="Fecha" />
                            <TableColumn fx:id="colTipoHist" prefWidth="100" text="Evento" />
                            <TableColumn fx:id="colMetodoHist" prefWidth="80" text="Método" />
                            <TableColumn fx:id="colHoraHist" prefWidth="80" text="Hora" />
                        </columns>
                    </TableView>
                </children>
            </VBox>
        </children>
    </HBox>

</VBox>
