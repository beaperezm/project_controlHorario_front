<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_LEFT" prefHeight="367.0" prefWidth="743.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectodam.fichappclient.controller.ControlHorario.ControlHorarioEmpleadorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <children>
            <Label text="Alta Rápida" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5D4037;" />
        </children>
    </HBox>

<TitledPane collapsible="false" text="Alta rápida de empleado">
    <content>
        <GridPane hgap="20" vgap="15">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
            </columnConstraints>

            <TextField fx:id="txtNombre" maxWidth="1.7976931348623157E308" promptText="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtApellidos" maxWidth="1.7976931348623157E308" promptText="Apellidos" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <TextField fx:id="txtEmail" maxWidth="1.7976931348623157E308" promptText="Email" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="txtDireccion" maxWidth="1.7976931348623157E308" promptText="Dirección" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <TextField fx:id="txtTelefono" maxWidth="1.7976931348623157E308" promptText="Teléfono" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="departamentoDTOComboBox" maxWidth="1.7976931348623157E308" prefHeight="25.0" promptText="Departamento" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <ComboBox fx:id="rolDTOComboBox" maxWidth="1.7976931348623157E308" prefHeight="25.0" promptText="Rol" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="txtDni" maxWidth="1.7976931348623157E308" promptText="DNI_NIE" GridPane.columnIndex="3" GridPane.rowIndex="1" />

            <DatePicker fx:id="datePickerFechaAlta" maxWidth="1.7976931348623157E308" promptText="Fecha Alta" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <DatePicker fx:id="datePickerFechaNacimiento" maxWidth="1.7976931348623157E308" promptText="Fecha Nac" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <ComboBox fx:id="tipoContratoComboBox" maxWidth="1.7976931348623157E308" prefHeight="25.0" promptText="Tipo Contrato" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <ComboBox fx:id="horarioComboBox" maxWidth="1.7976931348623157E308" prefHeight="25.0" promptText="Horario Base" GridPane.columnIndex="3" GridPane.rowIndex="2" />

            <Button fx:id="botonGuardar" maxWidth="1.7976931348623157E308" onAction="#botonGuardarEmpleado" prefHeight="35.0" text="Guardar Empleado" GridPane.columnIndex="3" GridPane.rowIndex="3" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            
            <rowConstraints>
               <RowConstraints minHeight="30.0" prefHeight="35.0" />
               <RowConstraints minHeight="30.0" prefHeight="35.0" />
               <RowConstraints minHeight="30.0" prefHeight="35.0" />
               <RowConstraints minHeight="35.0" prefHeight="40.0" />
            </rowConstraints>
        </GridPane>
    </content>
</TitledPane>

<TableView fx:id="tablaEmpleados" VBox.vgrow="ALWAYS" >
    <columnResizePolicy>
        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
    </columnResizePolicy>
        <columns>
            <TableColumn fx:id="columnaParaNombre" text="Nombre" prefWidth="150"/>
            <TableColumn fx:id="columnaParaApellido" text="Apellido" prefWidth="180" />
            <TableColumn fx:id="columnaParaCorreo" text="Email" prefWidth="160"/>
            <TableColumn fx:id="columnaParaDireccion" text="Dirección" prefWidth="180"/>
            <TableColumn fx:id="columnaParaTelefono" text="Teléfono" prefWidth="180"/>
            <TableColumn fx:id="columnaParaDepartamento" text="Departamento" prefWidth="190"/>
            <TableColumn fx:id="columnaParaRol" text="Rol" prefWidth="100"/>
            <TableColumn fx:id="columnaParaDni" text="DNI" prefWidth="100"/>
            <TableColumn fx:id="columnaParaFechaAlta" text="Fecha Alta" prefWidth="220"/>
            <TableColumn fx:id="columnaParaFechaNacimiento" text="Fecha Nacimiento" prefWidth="220"/>
            <TableColumn fx:id="columnaParaEstado" text="Estado" prefWidth="180"/>
        </columns>
</TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Editar" onAction="#botonEditarEmpleado" fx:id="botonEditar" />
        <Button text="Eliminar" onAction="#botonEliminarEmpleado" fx:id="botonEliminar"/>
    </HBox>



</VBox>
