<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.shape.Circle?>

<?import javafx.scene.control.ScrollPane?>


 <ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.proyectodam.fichappclient.controller.ControlHorario.EmpleadoDetalleController" fitToWidth="true" >
    <content>

        <VBox spacing="20" alignment="TOP_CENTER" style="-fx-background-color: #f4f6f9; -fx-padding: 20;">


            <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08),15,0,0,4);">
                <ImageView fx:id="imagenPerfil" fitHeight="120" fitWidth="120" preserveRatio="true">
                    <clip>
                        <Circle radius="60" centerX="60" centerY="60" />
                    </clip>
                </ImageView>

                <Label fx:id="nombreApellidos" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                <Label fx:id="email" style="-fx-text-fill: #7f8c8d"/>
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06),10,0,0,3);">
                <Label text="Información Personal" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <GridPane hgap="15" vgap="10">
                    <Label text="Dirección:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="direccion" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="telefono" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Departamento:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="departamento" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Rol:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="rol" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                </GridPane>

            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06),10,0,0,3);">
                <Label text="Información Laboral" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <GridPane hgap="15" vgap="10">

                    <Label text="Vacaciones Totales:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="vacacionesTotales" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Vacaciones Pendientes:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="vacacionesPendientes" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Horas Extra:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="horasExtra" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Horario:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="horario" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Configuración Horario:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <Label fx:id="configuracionHorario" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                </GridPane>

            </VBox>
        </VBox>

    </content>

</ScrollPane>
