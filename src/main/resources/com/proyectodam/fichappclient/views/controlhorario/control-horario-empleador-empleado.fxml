<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="367.0" prefWidth="743.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectodam.fichappclient.controller.ControlHorario.ControlHorarioEmpleadorEmpleadoController">
<padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
</padding>

    <TitledPane collapsible="false" text="Buscador" >
        <GridPane>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <TextField fx:id="buscarNombre" promptText="Buscar por nombre" GridPane.columnIndex="0" GridPane.rowIndex="0" prefHeight="30" prefWidth="1330"/>
        </GridPane>
    </TitledPane>

    <TitledPane collapsible="false" text="Filtro">
        <content>
            <GridPane hgap="15">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <columnConstraints>
                    <ColumnConstraints prefWidth="150" />
                      <ColumnConstraints prefWidth="150" />
                      <ColumnConstraints prefWidth="150" />
                      <ColumnConstraints prefWidth="150" />
                </columnConstraints>
                <ComboBox fx:id="filtrarRol" prefHeight="25.0" prefWidth="180.0" promptText="Rol" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="filtrarDepartamento" prefHeight="25.0" prefWidth="180.0" promptText="Departamento" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <ComboBox fx:id="filtrarEstado" prefHeight="25.0" prefWidth="180.0" promptText="Estado" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <DatePicker fx:id="filtrarFechaAlta" prefHeight="25.0" prefWidth="180.0" promptText="Fecha de Alta" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                <DatePicker fx:id="filtrarFechaNacimiento" prefHeight="25.0" prefWidth="180.0" promptText="Fecha de Nacimiento" GridPane.columnIndex="4" GridPane.rowIndex="1" />

                <Button prefHeight="25.0" prefWidth="151.0" text="Limpiar" GridPane.columnIndex="5" GridPane.rowIndex="1" onAction="#botonLimpiar"/>
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>
            </GridPane>
        </content>
    </TitledPane>

<TableView fx:id="tablaEmpleados" VBox.vgrow="ALWAYS" >
    <columnResizePolicy>
        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
    </columnResizePolicy>
        <columns>
            <TableColumn fx:id="columnaParaNombre" text="Nombre" prefWidth="150"/>
            <TableColumn fx:id="columnaParaApellido" text="Apellido" prefWidth="180" />
            <TableColumn fx:id="columnaParaCorreo" text="Email" prefWidth="160"/>
            <TableColumn fx:id="columnaParaDireccion" text="Dirección" prefWidth="180"/>
            <TableColumn fx:id="columnaParaTelefono" text="Teléfono" prefWidth="180"/>
            <TableColumn fx:id="columnaParaDepartamento" text="Departamento" prefWidth="190"/>
            <TableColumn fx:id="columnaParaRol" text="Rol" prefWidth="100"/>
            <TableColumn fx:id="columnaParaDni" text="DNI" prefWidth="100"/>
            <TableColumn fx:id="columnaParaFechaAlta" text="Fecha Alta" prefWidth="220"/>
            <TableColumn fx:id="columnaParaFechaNacimiento" text="Fecha Nacimiento" prefWidth="220"/>
            <TableColumn fx:id="columnaParaEstado" text="Estado" prefWidth="180"/>
        </columns>
</TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Editar" fx:id="botonEditar" onAction="#botonEditarEmpleado" />
        <Button text="Eliminar" fx:id="botonEliminar" onAction="#botonEliminarEmpleado"/>
        <Button text="Ver detalle" fx:id="botonVerDetalle" onAction="#botonVerDetalleEmpleado"/>
    </HBox>

    <TitledPane text="Resumen Empleados">
            <HBox spacing="20">

                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-padding: 30; -fx-border-color: #D5D8DC; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1),10,0,0,3);">
                    <Label text="Total Empleados" style="-fx-text-size: 14; -fx-text-fill: #7f8c8d"/>
                    <Label fx:id="totalEmpleadosLabel" text="0" style="-fx-font-size:28; -fx-font-weight:bold;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-padding: 30; -fx-border-color: #D5D8DC; -fx-border-radius: 10; -fx-border-width: 1.5;">  <!--style="-fx-background-color:#2E86C1;  -fx-background-raius: 10;" -->
                    <Label text="Activos"  style="-fx-text-size: 14; -fx-text-fill: #7f8c8d"/>
                    <Label fx:id="empleadosActivosLabel" text="0" style="-fx-font-size:28; -fx-font-weight:bold;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-padding: 30; -fx-border-color: #D5D8DC; -fx-border-radius: 10; -fx-border-width: 1.5;">
                    <Label text="Inactivos" style="-fx-text-size: 14; -fx-text-fill: #7f8c8d"/>
                    <Label fx:id="empleadosInactivosLabel" text="0" style="-fx-font-size:28; -fx-font-weight:bold;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-padding: 30; -fx-border-color: #D5D8DC; -fx-border-radius: 10; -fx-border-width: 1.5;">
                    <Label text="Baja Médica" style="-fx-text-size: 14; -fx-text-fill: #7f8c8d"/>
                    <Label fx:id="empleadosBajaMedicaLabel" text="0" style="-fx-font-size:28; -fx-font-weight:bold;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-padding: 30; -fx-border-color: #D5D8DC; -fx-border-radius: 10; -fx-border-width: 1.5;">
                    <Label text="Excedencia" style="-fx-text-size: 14; -fx-text-fill: #7f8c8d"/>
                    <Label fx:id="empleadosExcedenciaLabel" text="0" style="-fx-font-size:28; -fx-font-weight:bold;"/>
                </VBox>

            </HBox>
    </TitledPane>



</VBox>
